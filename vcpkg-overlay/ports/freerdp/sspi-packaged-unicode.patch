 	SECURITY_STATUS status = 0;
 	const SecurityFunctionTableW* table = nullptr;
-	Name = (SEC_WCHAR*)sspi_SecureHandleGetUpperPointer(phCredential);
+	Name = (SEC_WCHAR*)sspi_GetPackageNameW(sspi_SecureHandleGetUpperPointer_Real(phCredential));
 
 	if (!Name)
 		return SEC_E_SECPKG_NOT_FOUND;
@@ -1483,7 +1552,7 @@ static SECURITY_STATUS SEC_ENTRY winpr_SetCredentialsAttributesW(PCredHandle phC
 	SEC_WCHAR* Name = nullptr;
 	SECURITY_STATUS status = 0;
 	const SecurityFunctionTableW* table = nullptr;
